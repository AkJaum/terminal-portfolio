# Copy this file to .env on the Ubuntu server and replace placeholder values.
# Do not commit the final .env file.

# Public port mappings
APP_PORT=3000
RUNNER_PORT=8080

# App <-> Runner integration
PROJECT_RUNNER_URL=https://runner.example.com
RUNNER_SHARED_TOKEN=replace-with-a-long-random-token
PROJECT_IDLE_CLEANUP_MS=60000

# Django/runner core security
DJANGO_SECRET_KEY=replace-with-a-long-random-django-secret
DJANGO_ALLOWED_HOSTS=runner.example.com,localhost,127.0.0.1,project-runner
WORKDIR_BASE=/tmp/runner-workspaces

# Rate limit and overload protection
MAX_REQUESTS_PER_ID_PER_MINUTE=120
RATE_WINDOW_SECONDS=60
MAX_CONCURRENT_REQUESTS_PER_ID=6
MAX_GLOBAL_CONCURRENT_REQUESTS=64
PENDING_REQUEST_TTL_SECONDS=30

# Runtime command controls
BUILD_TIMEOUT_MS=30000
RUN_TIMEOUT_MS=10000
MAX_OUTPUT_BYTES=262144

# Optional project repo overrides
PROJECT_REPO_PUSH_SWAP=https://github.com/AkJaum/push_swap.git
PROJECT_REPO_GET_NEXT_LINE=https://github.com/AkJaum/get_next_line.git
PROJECT_REPO_PRINTF=https://github.com/AkJaum/ft_printf.git
PROJECT_REPO_LIBFT=https://github.com/AkJaum/libft.git
